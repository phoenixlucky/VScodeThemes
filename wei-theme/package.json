{
  "name": "wei-glass-theme",
  "displayName": "Wei Glass Theme",
  "description": "A glassmorphism VS Code theme — translucent panels with classical Chinese elegance (胭脂/玉/金/紫). Background wallpaper included.",
  "version": "1.4.0",
  "icon": "./icon.png",
  "main": "./extension.js",
  "publisher": "EthanWilkins",
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "categories": [
    "Themes",
    "Other"
  ],
  "license": "GPL-3.0",
  "keywords": [
    "theme",
    "color-theme",
    "glassmorphism",
    "glass",
    "classical",
    "elegant",
    "dark",
    "light"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/phoenixlucky/VScodeThemes.git"
  },
  "contributes": {
    "commands": [
      {
        "command": "weiGlass.switchDark",
        "title": "Wei Glass: 切换到深色主题"
      },
      {
        "command": "weiGlass.switchLight",
        "title": "Wei Glass: 切换到浅色主题"
      },
      {
        "command": "weiGlass.toggleTheme",
        "title": "Wei Glass: 深色/浅色一键切换"
      },
      {
        "command": "weiGlass.applySetupGuide",
        "title": "Wei Glass: 推荐设置引导"
      },
      {
        "command": "weiGlass.showWallpaperTip",
        "title": "Wei Glass: 查看壁纸说明"
      }
    ],
    "configuration": {
      "title": "Wei Glass",
      "properties": {
        "weiGlass.showWallpaperTip": {
          "type": "boolean",
          "default": true,
          "description": "首次安装时显示壁纸和功能介绍提示"
        }
      }
    },
    "themes": [
      {
        "label": "Wei Glass",
        "uiTheme": "vs-dark",
        "path": "./themes/wei-glass-dark.json"
      },
      {
        "label": "Wei Glass Light",
        "uiTheme": "vs",
        "path": "./themes/wei-glass-light.json"
      }
    ]
  }
}
