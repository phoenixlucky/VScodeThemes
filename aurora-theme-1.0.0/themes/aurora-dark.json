    "terminal.ansiBrightCyan": "#b4f9f8",
    "terminal.ansiBrightWhite": "#d5d6db",

    "scrollbar.shadow": "#00000088",
    "scrollbarSlider.background": "#292e4288",
    "scrollbarSlider.hoverBackground": "#3b4261aa",
    "scrollbarSlider.activeBackground": "#7dcfffaa",

    "badge.background": "#292e42",
    "badge.foreground": "#c0caf5",
    "progressBar.background": "#7dcfff",
    "notificationCenterHeader.background": "#16161e",
    "notificationCenter.border": "#292e42",
    "notifications.background": "#16161e",
    "notifications.foreground": "#c0caf5",
    "notifications.border": "#292e42",
    "notificationLink.foreground": "#7dcfff",
    "button.background": "#7dcfff",
    "button.foreground": "#1a1b26",
    "button.hoverBackground": "#8dd9ff",
    "button.secondaryBackground": "#292e42",
    "button.secondaryForeground": "#c0caf5",
    "button.secondaryHoverBackground": "#3b4261",
    "input.background": "#0f0f17",
    "input.foreground": "#c0caf5",
    "input.border": "#292e42",
    "inputOption.activeBackground": "#292e42",
    "inputOption.activeBorder": "#7dcfff",
    "inputOption.activeForeground": "#c0caf5",
    "inputPlaceholder.foreground": "#565f89",
    "checkbox.background": "#0f0f17",
    "checkbox.border": "#292e42",
    "dropdown.background": "#0f0f17",
    "dropdown.foreground": "#c0caf5",
    "dropdown.border": "#292e42",
    "list.activeSelectionBackground": "#292e42",
    "list.activeSelectionForeground": "#c0caf5",
    "list.hoverBackground": "#1f2335",
    "list.hoverForeground": "#c0caf5",
    "list.inactiveSelectionBackground": "#1f2335",
    "list.inactiveSelectionForeground": "#c0caf5",
    "list.focusBackground": "#292e42",
    "list.highlightForeground": "#7dcfff",
    "listFilterWidget.background": "#16161e",
