    "gitDecoration.modifiedResourceForeground": "#e0af68",
    "gitDecoration.deletedResourceForeground": "#f7768e",
    "gitDecoration.untrackedResourceForeground": "#7dcfff",
    "gitDecoration.ignoredResourceForeground": "#565f89",
    "gitDecoration.conflictingResourceForeground": "#bb9af7",
    "minimap.findMatchHighlight": "#e0af6855",
    "minimap.selectionHighlight": "#7dcfff40",
    "minimap.errorHighlight": "#f7768e",
    "minimap.warningHighlight": "#e0af68",
    "minimapGutter.addedBackground": "#9ece6a",
    "minimapGutter.modifiedBackground": "#e0af68",
    "minimapGutter.deletedBackground": "#f7768e"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "comment.line.documentation",
        "comment.block.documentation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#565f89",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.triple",
        "string.template",
        "string.interpolated",
        "string.regexp",
        "string.unquoted"
      ],
      "settings": {
        "foreground": "#9ece6a"
      }
    },
    {
      "name": "Number / Constant",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other"
      ],
      "settings": {
        "foreground": "#ff9e64"
      }
    },
    {
      "name": "Boolean",
      "scope": [
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#ff9e64",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.operator.new",
        "keyword.other",
        "keyword.other.special-method",
        "keyword.other.unit",
        "storage",
        "storage.type",
        "storage.modifier",
        "storage.control"
      ],
      "settings": {
        "foreground": "#bb9af7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.relational"
      ],
      "settings": {
        "foreground": "#bb9af7"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.definition.string",
        "punctuation.definition.comment",
        "punctuation.definition.tag",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor",
        "meta.brace",
        "meta.bracket",
        "meta.parens"
      ],
      "settings": {
        "foreground": "#a9b1d6"
      }
    },
    {
      "name": "Function / Method",
      "scope": [
        "entity.name.function",
        "support.function",
        "support.function.builtin",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#7dcfff"
      }
    },
    {
      "name": "Function declaration",
      "scope": [
        "meta.function",
        "meta.method",
        "meta.function.declaration",
        "meta.function.method.declaration"
      ],
      "settings": {
        "foreground": "#7dcfff"
      }
    },
    {
      "name": "Function call",
      "scope": [
        "entity.name.function.call",
        "support.function.magic",
        "variable.other.functioncall"
      ],
      "settings": {
        "foreground": "#7dcfff"
      }
    },
    {
      "name": "Parameter",
      "scope": [
        "variable.parameter",
        "variable.parameter.function"
      ],
      "settings": {
        "foreground": "#e0af68",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#c0caf5"
      }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#7dcfff"
      }
    },
    {
      "name": "Class / Type",
      "scope": [
        "entity.name.class",
        "entity.name.type.class",
        "entity.name.type",
        "entity.name.namespace",
        "support.class",
        "support.type",
        "support.type.primitive",
        "support.type.builtin",
        "support.type.typename",
        "entity.other.inherited-class",
        "meta.class",
        "meta.type"
      ],
      "settings": {
        "foreground": "#e0af68",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Interface / Enum",
      "scope": [
        "entity.name.interface",
        "entity.name.enum",
        "entity.name.type.interface",
        "entity.name.type.enum",
        "support.type.interface",
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#e0af68"
      }
    },
    {
      "name": "Tag (HTML / JSX)",
      "scope": [
        "entity.name.tag",
        "entity.name.tag.html",
        "entity.name.tag.jsx",
        "entity.name.tag.xml",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#f7768e"
      }
    },
    {
      "name": "Attribute name",
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute-name.html",
        "entity.other.attribute-name.jsx",
        "entity.other.attribute-name.xml",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#e0af68"
      }
    },
    {
      "name": "Decorator / Annotation",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "punctuation.decorator",
        "meta.annotation"
      ],
      "settings": {
        "foreground": "#ff9e64"
      }
    },
    {
      "name": "Built-in constant",
      "scope": [
        "support.constant",
        "support.constant.property-value"
      ],
      "settings": {
        "foreground": "#f7768e"
      }
    },
    {
      "name": "Built-in variable / Module",
      "scope": [
        "support.variable",
        "support.variable.builtin",
        "support.variable.module",
        "support.module"
      ],
      "settings": {
        "foreground": "#bb9af7"
      }
    },
    {
      "name": "JSON Key",
      "scope": [
        "support.type.property-name.json",
        "meta.object.member.key.json",
        "string.quoted.key.json"
      ],
      "settings": {
        "foreground": "#7dcfff"
      }
    },
    {
      "name": "JSON String",
      "scope": [
        "string.quoted.double.json",
        "string.quoted.single.json"
      ],
      "settings": {
        "foreground": "#9ece6a"
      }
    },
    {
      "name": "YAML key",
      "scope": [
        "entity.name.tag.yaml",
        "meta.mapping.key.yaml"
      ],
      "settings": {
        "foreground": "#7dcfff"
      }
    },
    {
      "name": "CSS Property",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.scss",
        "support.type.property-name.less",
        "meta.property-name.css"
      ],
      "settings": {
        "foreground": "#7dcfff"
      }
    },
    {
      "name": "CSS Class / ID",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#e0af68"
      }
    },
    {
      "name": "CSS Value",
      "scope": [
        "support.constant.property-value.css",
        "meta.property-value.css"
      ],
      "settings": {
        "foreground": "#9ece6a"
      }
    },
    {
      "name": "Markdown heading",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#7dcfff",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold/italic",
      "scope": [
        "markup.bold",
        "markup.italic"
      ],
      "settings": {
        "foreground": "#e0af68"
      }
    },
    {
      "name": "Markdown inline code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#9ece6a"
      }
    },
    {
      "name": "Markdown link",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#bb9af7"
      }
    },
    {
      "name": "Diff added",
      "scope": [
        "markup.inserted",
        "diff.inserted"
      ],
      "settings": {
        "foreground": "#9ece6a"
      }
    },
    {
      "name": "Diff removed",
      "scope": [
        "markup.deleted",
        "diff.deleted"
      ],
      "settings": {
        "foreground": "#f7768e"
      }
    },
    {
      "name": "Diff changed",
      "scope": [
        "markup.changed",
        "diff.changed"
      ],
      "settings": {
        "foreground": "#e0af68"
      }
    },
    {
      "name": "Invalid / Error",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#f7768e",
        "fontStyle": "underline"
      }
    }
  ]
}
