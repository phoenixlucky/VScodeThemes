    "listFilterWidget.noMatchesOutline": "#f7768e",
    "tree.indentGuidesStroke": "#292e42",
    "breadcrumb.background": "#1a1b26",
    "breadcrumb.foreground": "#a9b1d6",
    "breadcrumb.focusForeground": "#c0caf5",
    "breadcrumb.activeSelectionForeground": "#7dcfff",
    "breadcrumbPicker.background": "#16161e",
    "merge.border": "#292e42",
    "merge.commonContentBackground": "#292e42",
    "merge.commonHeaderBackground": "#292e4288",
    "merge.currentContentBackground": "#9ece6a33",
    "merge.currentHeaderBackground": "#9ece6a55",
    "merge.incomingContentBackground": "#7dcfff33",
    "merge.incomingHeaderBackground": "#7dcfff55",
    "editorOverviewRuler.border": "#1a1b26",
    "editorOverviewRuler.findMatchForeground": "#e0af68",
    "editorOverviewRuler.selectionHighlightForeground": "#7dcfff55",
