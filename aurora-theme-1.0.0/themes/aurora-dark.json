{
  "name": "Aurora Dark",
  "type": "dark",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "parameter": {
      "foreground": "#e0af68",
      "fontStyle": "italic"
    },
    "variable.parameter": {
      "foreground": "#e0af68"
    },
    "property": {
      "foreground": "#7dcfff"
    },
    "variable": {
      "foreground": "#c0caf5"
    },
    "variable.readonly": {
      "foreground": "#bb9af7"
    },
    "type": {
      "foreground": "#e0af68"
    },
    "class": {
      "foreground": "#e0af68",
      "fontStyle": "bold"
    },
    "function": {
      "foreground": "#7dcfff"
    },
    "method": {
      "foreground": "#7dcfff"
    },
    "string": {
      "foreground": "#9ece6a"
    },
    "number": {
      "foreground": "#ff9e64"
    },
    "boolean": {
      "foreground": "#ff9e64"
    },
    "keyword": {
      "foreground": "#bb9af7",
      "fontStyle": "italic"
    },
    "comment": {
      "foreground": "#565f89",
      "fontStyle": "italic"
    }
  },
  "colors": {
