    "editor.findMatchBackground": "#ff9e6444",
    "editor.findMatchHighlightBackground": "#ff9e6422",
    "editor.findRangeHighlightBackground": "#7c3aed18",
    "editor.hoverHighlightBackground": "#0c7ea410",
    "editorIndentGuide.background1": "#d8d8e0",
    "editorIndentGuide.activeBackground1": "#b4b8c8",
