    "statusBar.background": "#e0e0e8",
    "statusBar.foreground": "#4a5068",
    "statusBar.border": "#d0d0d8",
    "statusBar.debuggingBackground": "#7c3aed",
    "statusBar.debuggingForeground": "#ffffff",
    "statusBar.noFolderBackground": "#e0e0e8",
    "statusBarItem.prominentBackground": "#d8d8e0",
    "statusBarItem.prominentHoverBackground": "#c8c8d0",
    "statusBarItem.hoverBackground": "#d8d8e0",
    "statusBarItem.activeBackground": "#c8c8d0",

    "panel.background": "#ececf2",
    "panel.border": "#d0d0d8",
