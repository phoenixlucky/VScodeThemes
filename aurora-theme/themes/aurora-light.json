{
  "name": "Aurora Light",
  "type": "light",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "parameter": {
      "foreground": "#9a6f00",
      "fontStyle": "italic"
    },
    "variable.parameter": {
      "foreground": "#9a6f00"
    },
    "property": {
      "foreground": "#0c7ea4"
    },
    "variable": {
      "foreground": "#1a1b26"
    },
    "variable.readonly": {
      "foreground": "#7c3aed"
    },
    "type": {
      "foreground": "#9a6f00"
    },
    "class": {
      "foreground": "#9a6f00",
      "fontStyle": "bold"
    },
    "function": {
      "foreground": "#0c7ea4"
    },
    "method": {
      "foreground": "#0c7ea4"
    },
    "string": {
      "foreground": "#4a7a1f"
    },
    "number": {
      "foreground": "#c2540a"
    },
    "boolean": {
      "foreground": "#c2540a"
    },
    "keyword": {
      "foreground": "#7c3aed",
      "fontStyle": "italic"
    },
    "comment": {
      "foreground": "#8a8fa3",
      "fontStyle": "italic"
    }
  },
  "colors": {
    "focusBorder": "#0c7ea4",
    "foreground": "#1a1b26",
    "disabledForeground": "#a0a5b8",
    "widget.shadow": "#00000022",
